{
  "model": "google/gemma-4-12b-qat",
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:1234",
    "ANTHROPIC_AUTH_TOKEN": "PASTE_LMSTUDIO_TOKEN_HERE",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_THINKING": "1",
    "CLAUDE_MODEL": "google/gemma-4-12b-qat",
    "LMSTUDIO_MODEL": "google/gemma-4-12b-qat",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "google/gemma-4-12b-qat",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "google/gemma-4-12b-qat",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "google/gemma-4-12b-qat",
    "CLAUDE_CODE_SUBAGENT_MODEL": "google/gemma-4-12b-qat",
    "LM_STUDIO_VISION_MODEL": "google/gemma-4-12b-qat"
  },
  "permissions": {
    "allow": [
      "mcp__wifi-cam__*",
      "mcp__usb-webcam__*",
      "mcp__memory__*",
      "mcp__sociality__*",
      "mcp__system-temperature__*",
      "mcp__tts__*",
      "mcp__desire-system__*",
      "Read(//c/Users/ma/src/embodied-claude/**)",
      "Edit(//c/Users/ma/src/embodied-claude/**)",
      "Write(//c/Users/ma/src/embodied-claude/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/run_auto_context.cmd\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
