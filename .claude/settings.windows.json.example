{
  "permissions": {
    "allow": [
      "mcp__wifi-cam__*",
      "mcp__usb-webcam__*",
      "mcp__memory__*",
      "mcp__sociality__*",
      "mcp__system-temperature__*",
      "mcp__tts__*",
      "mcp__desire-system__*",
      "Read(//c/Users/ma/src/embodied-claude/**)",
      "Edit(//c/Users/ma/src/embodied-claude/**)",
      "Write(//c/Users/ma/src/embodied-claude/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/run_auto_context.cmd\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
