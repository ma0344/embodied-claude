{
  "mcpServers": {
    "memory": {
      "command": "${env:HOME}/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "${workspaceFolder}/memory-mcp",
        "memory-mcp"
      ],
      "env": {
        "UV_PYTHON": "3.12",
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
      }
    },
    "system-temperature": {
      "command": "${env:HOME}/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "${workspaceFolder}/system-temperature-mcp",
        "system-temperature-mcp"
      ],
      "env": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
      }
    },
    "sociality": {
      "command": "${env:HOME}/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "${workspaceFolder}/sociality-mcp",
        "sociality-mcp"
      ],
      "env": {
        "UV_PYTHON": "3.12",
        "SOCIAL_POLICY_PATH": "${workspaceFolder}/socialPolicy.toml",
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
      }
    },
    "tts": {
      "command": "${env:HOME}/.local/bin/uv",
      "args": [
        "run",
        "--extra",
        "all",
        "--directory",
        "${workspaceFolder}/tts-mcp",
        "tts-mcp"
      ],
      "env": {
        "TTS_PLAYBACK": "auto",
        "ELEVENLABS_PLAY_AUDIO": "false",
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
      }
    },
    "wifi-cam": {
      "command": "${env:HOME}/.local/bin/uv",
      "args": [
        "run",
        "--extra",
        "transcribe",
        "--directory",
        "${workspaceFolder}/wifi-cam-mcp",
        "wifi-cam-mcp"
      ],
      "env": {
        "TAPO_CAMERA_HOST": "${env:TAPO_CAMERA_HOST}",
        "TAPO_USERNAME": "${env:TAPO_USERNAME}",
        "TAPO_PASSWORD": "${env:TAPO_PASSWORD}",
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
      }
    }
  }
}
