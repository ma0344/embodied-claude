{
  "mcpServers": {
    "memory": {
      "command": "uv",
      "args": [
        "run",
        "--no-sync",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\memory-mcp",
        "memory-mcp"
      ],
      "env": {
        "UV_PYTHON": "3.12",
        "MEMORY_HTTP_PORT": "18900",
        "AGENT_NAME": "こより"
      }
    },
    "desire-system": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\desire-system",
        "desire-system"
      ],
      "env": {
        "AGENT_NAME": "こより"
      }
    },
    "system-temperature": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\system-temperature-mcp",
        "system-temperature-mcp"
      ]
    },
    "sociality": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\sociality-mcp",
        "sociality-mcp"
      ],
      "env": {
        "UV_PYTHON": "3.12",
        "SOCIAL_POLICY_PATH": "C:\\Users\\ma\\src\\embodied-claude\\socialPolicy.toml",
        "AGENT_NAME": "こより"
      }
    },
    "tts": {
      "command": "uv",
      "args": [
        "run",
        "--extra",
        "all",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\tts-mcp",
        "tts-mcp"
      ],
      "env": {
        "TTS_PLAYBACK": "auto",
        "ELEVENLABS_PLAY_AUDIO": "false"
      }
    },
    "wifi-cam": {
      "command": "uv",
      "args": [
        "run",
        "--extra",
        "transcribe",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\wifi-cam-mcp",
        "wifi-cam-mcp"
      ],
      "env": {
        "TAPO_CAMERA_HOST": "192.168.1.XXX",
        "TAPO_USERNAME": "your-username",
        "TAPO_PASSWORD": "your-password",
        "WIFI_CAM_TEXT_ONLY_TOOL_RESULT": "true",
        "WIFI_CAM_VISION_DESCRIBE": "true",
        "ANTHROPIC_BASE_URL": "http://127.0.0.1:1234",
        "CLAUDE_MODEL": "google/gemma-4-12b-qat"
      }
    },
    "usb-webcam": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:\\Users\\ma\\src\\embodied-claude\\usb-webcam-mcp",
        "usb-webcam-mcp"
      ]
    }
  }
}
