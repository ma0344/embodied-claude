# presence-ui optional flags — copy to:
#   %USERPROFILE%\.config\embodied-claude\presence-ui.local.env
# Loaded by run-presence-ui-worker.ps1 and presence_ui.repo_env.load_repo_env()
# Do NOT commit the real file (secrets).

# ── Surface direct LLM（native chat 本線 — Claude Code 子プロセスなし）────────
# PRESENCE_SURFACE_DIRECT=1          # 既定 ON — LM Studio /v1/chat/completions 直叩き
# PRESENCE_SURFACE_USE_CLAUDE=1      # legacy: CC 子プロセスに戻す
# PRESENCE_SURFACE_HISTORY_TURNS=12  # 表層プロンプトに載せる直近ターン数
# PRESENCE_SURFACE_MAX_TOKENS=500
# PRESENCE_SOUL_CORE_IN_APPEND=1     # SOUL core を gateway system に注入（Surface Direct 本線）
# PRESENCE_SURFACE_SESSIONS_DIR=   # 省略時 %USERPROFILE%\.claude\koyori-surface\sessions
# ※ 値を空のまま行全体を有効にすると dotenv が「# 省略時…」をパスと解釈し
#    presence-ui 配下に誤ったディレクトリができる。使うときはコメント行のままにするか、
#    パスだけを書く（例: PRESENCE_SURFACE_SESSIONS_DIR=C:\Users\ma\.claude\koyori-surface\sessions）
# PRESENCE_PERSONA_EXPORT_SURFACE=1  # Persona export に surface JSONL を含める

PRESENCE_NATIVE_CHAT=1

# ── GW-S1 Claude resume（表 chat 直後 internal turn、KV 再利用）────────
# PRESENCE_GW_S1_CLAUDE=1           # session_id 付き internal → Claude --resume（既定 OFF）
# PRESENCE_GW_AFTER_CHAT=1          # smoke のみ（native chat からは未配線 — PAUSE は自律 tick）
# PRESENCE_GW_INTERNAL_MAX_TURNS=1  # internal turn の max_turns
# PRESENCE_GW_S1_TIMEOUT=90

# ── GW-S2 OL-GATE / TEMP-C staged classification ─────────────────
# PRESENCE_GW_S2_ENABLED=1          # ingest 後 LLM 分類（既定 OFF）
# PRESENCE_GW_S2_STAGED=1           # TEMP-C3: Stage1→2 events[]（要 GW_S2_ENABLED）
# PRESENCE_GW_CORRECTION_ROUTING=1  # SHIFT-R2: correction kind → correction_target → store ルーティング
# PRESENCE_GW_S2_FALLBACK_RULES=0   # 1=分類失敗時 v0 ルール loop
# PRESENCE_GW_S2_TIMEOUT=45
# PRESENCE_TEMP_C_STAGE1_MAX_TOKENS=420
# PRESENCE_TEMP_C_STAGE2_MAX_TOKENS=768
#
# PFC-1: 前頭葉 classifier を表層 12B から分離（LM Studio で e4b-qat を別ロード）
# PRESENCE_CLASSIFIER_MODEL=google/gemma-4-e4b-qat
# PRESENCE_CLASSIFIER_BASE_URL=   # 省略時は LM_STUDIO_BASE_URL / ANTHROPIC_BASE_URL と同じ
#
# Vision（wifi-cam describe / tick observe_room）— 表層と同じ 12b-qat（wifi_cam_mcp.vision）
# LM_STUDIO_VISION_MODEL は非推奨（legacy e4b スロット）。設定しても describe では無視される。
# 明示 override のみ: PRESENCE_VISION_MODEL=google/gemma-4-12b-qat
# WIFI_CAM_VISION_MAX_SIDE=1024
# WIFI_CAM_VISION_MAX_TOKENS=720
# WIFI_CAM_VISION_PROMPT=この写真の見えているものを具体的に日本語で書いてください。人物・姿勢・家具・明るさ・窓やモニタの有無。推測や見えないことは書かない。5〜8文程度。箇条書きや見出しは使わず地の文のみ。
#
# OL5-c: loop 作成時 e4b で completion_verbs 拡張（提出した 等）— 既定 ON
# PRESENCE_OL5_C_ENABLED=1
# PRESENCE_OL5_C_MAX_TOKENS=280
#
# Irodori TTS emoji enrich — TTS 直前 e4b（表層 reply は plain のまま · docs/irodori-tts-API-for-Python.md）
# PRESENCE_IRODORI_EMOJI_ENRICH=1
# PRESENCE_IRODORI_EMOJI_MAX_TOKENS=256
#
# OL7: return-signal close（日本語検定型 · 合図→確認→close 共有 pending_check）
# 要 PRESENCE_GW_S2_ENABLED=1 + PRESENCE_CLASSIFIER_MODEL=e4b-qat（上記 PFC-1）
# PRESENCE_OL7_ENABLED=1
# PRESENCE_OL7_IMMEDIATE_CONFIDENCE=0.9   # explicit_completion の即 close 閾値（return_signal は確認経路）
# PRESENCE_OL7_MAX_TOKENS=320

# MEM-8b 退縮実験: 0 で schedule_facts / temporal must_include を切る（tier 0–2 のみで答えるか試す）
# PRESENCE_TEMPORAL_SCHEDULE_CONTRACT=0
#
# MEM-8b stage-2: compose 第1段で mentionable が薄いとき gateway が追加 recall（LM ツールループなし）
# PRESENCE_COMPOSE_RECALL_STAGE2=1
# PRESENCE_COMPOSE_RECALL_STAGE2_DIVERGENT=1
# PRESENCE_COMPOSE_RECALL_STAGE2_N=6
#
# MEM-8h — memory bridge route gate (B) + bridge recall (C)
# PRESENCE_MEM8H_ROUTE=1
# PRESENCE_MEM8H_BRIDGE=1
# PRESENCE_MEM8H_BRIDGE_KEYWORDS=3
# PRESENCE_MEM8H_BRIDGE_N=2
# PRESENCE_MEM8H_BRIDGE_MAX_LINES=3
# PRESENCE_MEM8H_BRIDGE_FACT_REFS=2

# ── 青空読書（LW-READ）— 一節の長さ ────────────────────────────────
# 既定 3200（2026-07-08: 1600→倍。内面拡張のため一塊を厚くする試行値）
# PRESENCE_AOZORA_PASSAGE_MAX_CHARS=3200
# 同一節 reread_same の上限（既定 2。超えたら advance 強制）
# PRESENCE_AOZORA_REREAD_SAME_MAX=2

# ── LW-7 青空読書 → Web 連鎖（PAUSE followup_query → inward tick DDG）────────
# 1=有効（既定 OFF）— PAUSE で載った pending_followup_query を次 tick で消費
PRESENCE_LW7_ENABLED=1

# ── OBS-TICK-1b — 視点(preset)ごと baseline + phash 信号ログ ──────────
# observe_room は dining preset(3) 単キャプチャ → dining baseline と比較。
# look_outside=window(1) / look_desk=desk(2) も各 baseline と比較。
# preset ID は wifi-cam-mcp/.env（TAPO_WINDOW_PRESET など）で解決。
PRESENCE_OBS_TICK_1B=1
# センサー時間ノイズ潰し: ハッシュ/MAE 前に GaussianBlur（0 で無効、既定 1.0）
# PRESENCE_ROOM_BLUR_RADIUS=1.0
# baseline 元画像（省略時はコード内の既定 Downloads パス）
# PRESENCE_ROOM_BASELINE_IMAGE_WINDOW=C:\...\window.jpg
# PRESENCE_ROOM_BASELINE_IMAGE_DESK=C:\...\ma-desk.jpg
# PRESENCE_ROOM_BASELINE_IMAGE_DINING=C:\...\dining.jpg
# PRESENCE_ROOM_BASELINES_PATH=  # 省略時 %USERPROFILE%\.claude\presence-ui\room_baselines.json
# PRESENCE_ROOM_SIGNALS_PATH=    # 省略時 …\room_scene_signals.jsonl
# 開発用: tick フレームを JPG 保存（犬/人/ノイズの目視切り分け）。既定 OFF。
# ファイル名に hamming 値: 20260707T173517_b14_p2_dctb14_dctp2.jpg
# PRESENCE_ROOM_SAVE_FRAMES=1
# PRESENCE_ROOM_FRAMES_MAX=200   # view ごと保持枚数（リングバッファ）

# ── USB 外カメラ — 廃止（2026-07-06）────────────────────────────────
# look_outside / 窓は Tapo window preset のみ。PRESENCE_USB_CAMERA_ENABLED は無視される。

# ── Near-eye（Surface / koyori Phase 1+2）──────────────────────────
# koyori: http://koyori.local:8765/{health,latest.jpg,see}
# presence-ui: GET /api/v1/near-camera/{health,snapshot}
KOYORI_CAM_URL=http://koyori.local:8765
# PRESENCE_NEAR_CAMERA_TIMEOUT_SECONDS=8
# PRESENCE_NEAR_CAMERA_SEE_TIMEOUT_SECONDS=25
# PRESENCE_NEAR_CAMERA_REFRESH=0    # 1=常に /see（遅い）
# PRESENCE_NEAR_CAMERA_DESCRIBE=0   # 1=snapshot で caption 既定 ON
# PRESENCE_NEAR_LOOK_FRESH=0        # look_near smoke で /see を使う

# ── Lite context limits（native chat / Room 注入）────────────────
# ma-home LM Studio ctx ~87k 向け既定。8192 時代は 1200/2500 だった。
# PRESENCE_LITE_COMPOSE_MAX_CHARS=8000
# PRESENCE_LITE_APPEND_MAX_CHARS=12000
# PRESENCE_ENRICH_MAX_CHARS=12000
# PRESENCE_LITE_STM_MAX_CHARS=2500
# PRESENCE_COMPOSE_MAX_CHARS=10000

# ── WS Web 検索・URL prefetch（gateway / WS-1〜2c）──────────────────
# 会話の「調べて」→ gateway が Brave 検索 +（必要なら）ページ excerpt を注入。
# Claude Code の WebSearch/WebFetch は使わない。変更後は scripts/restart-presence-ui.ps1
#
# WS-3: CC WebSearch/WebFetch を settings.local.json で deny（Sources 捏造防止）
#   1=有効（既定）  0=無効（CC ツールに戻す — 非推奨）
# PRESENCE_WS_GUARD=1
#
# WS-2a: 「調べて」「ネットで」等で会話検索 prefetch
#   1=有効（既定）  0=オフ
# PRESENCE_WEB_SEARCH_PREFETCH=1
#
# WS-2b: 検索バックエンド
#   auto = BRAVE_SEARCH_API_KEY があれば Brave、なければ DDG Instant
#   brave = Brave のみ  ddg / instant = DDG Instant のみ
PRESENCE_WEB_SEARCH_BACKEND=brave
# Brave Search API キー（https://api-dashboard.search.brave.com/）
BRAVE_SEARCH_API_KEY=PASTE_BRAVE_KEY_HERE
# Brave: 検索結果件数（1〜5、既定 3）
# PRESENCE_WEB_SEARCH_MAX_RESULTS=3
# Brave: 国・言語（日本の行政ページ向け）
# PRESENCE_WEB_SEARCH_COUNTRY=JP
# PRESENCE_WEB_SEARCH_LANG=jp
#
# WS-2c: 検索候補 or まー貼付 URL の HTML → excerpt（本文根拠）
#   1=有効（既定）  0=オフ
PRESENCE_URL_PREFETCH=1
# excerpt 上限（字）。既定 6000、最大 8000
PRESENCE_URL_PREFETCH_MAX_CHARS=6000
# まーがメッセージに URL を貼ったとき、最大何件読むか（1〜3）
# PRESENCE_URL_PREFETCH_MAX_URLS=2
# 検索後: 候補 URL を順に fetch（1件目が薄いとき 2・3 件目へ）
PRESENCE_URL_PREFETCH_SEARCH_MAX_ATTEMPTS=3
# 1 URL あたり GET タイムアウト（秒）
# PRESENCE_URL_PREFETCH_TIMEOUT_SEC=12
# HTML ダウンロード上限（バイト）。超えたら打ち切り
# PRESENCE_URL_PREFETCH_MAX_BYTES=1048576

# ── WS-2d: PDF 抽出（テキスト埋め込み PDF のみ）────────────────────
# URL の PDF / まー貼付のローカルパス（"C:\...\x.pdf"・file:///…）を
# PyMuPDF でテキスト抽出 → excerpt。スキャン(画像)PDF は status=pdf_scanned で
# 正直に「読めへん」と返す（OCR/VLM は Phase 2 未配線）。
# 1=有効（既定）  0=オフ
# PRESENCE_PDF_EXTRACT=1
# 抽出ページ上限（既定 50 / 最大 500）
# PRESENCE_PDF_MAX_PAGES=50
# 抽出文字上限（既定 20000 / 最大 100000）。excerpt 前の生テキスト上限
# PRESENCE_PDF_MAX_CHARS=20000
# PDF サイズ上限（バイト・既定 20MiB）。ローカル/DL 共通
# PRESENCE_PDF_MAX_BYTES=20971520
# ローカルパス読取を許可するルート（os.pathsep 区切り）。既定はユーザ home 配下のみ。
# home の外を読ませたいときだけ明示（任意ファイル読取の境界）
# PRESENCE_PDF_ALLOW_DIRS=C:\Users\ma\Downloads;C:\Users\ma\Documents

# ── DOC-READ: 長文書 ingest + 本の地図（A/B）────────────────────────
# CLI: doc-read ingest <pdf>  /  doc-read map <doc_id>  /  doc-read show <doc_id>
# store 既定: ~/.claude/presence-ui/docs/{doc_id}/
# PRESENCE_DOC_STORE_DIR=
# chunk サイズ（見出し無し時の固定長分割。章境界ありなら章単位）
# PRESENCE_DOC_CHUNK_CHARS=8000
# PRESENCE_DOC_CHUNK_OVERLAP=400
# 章見出し行の最大長（本文中参照「第１章でも…」を除外）
# PRESENCE_DOC_HEADING_MAX_LEN=40
# ── DOC-READ C: 会話への地図/章 注入 ──
# 1=有効（既定） 0=オフ
# PRESENCE_DOC_CONTEXT=1
# 本モードの継続ターン数（cue/タイトルで開き、cue無しでも継続→decay）
# PRESENCE_DOC_STICKY_TURNS=3
# 1ターンで注入する該当章 chunk 上限
# PRESENCE_DOC_RETRIEVE_MAX_CHUNKS=2
# 地図・各章の注入文字上限
# PRESENCE_DOC_MAP_MAX_CHARS=4000
# PRESENCE_DOC_CHUNK_MAX_CHARS=3000
# D: map gist → memory-mcp（A: map 直後 · B: 初回議論）
# PRESENCE_DOC_MEMORY=1
# PRESENCE_DOC_MEMORY_GIST_MAX_CHARS=3500

# ── GAPI Google Calendar prefetch（prep-3）────────────────────────
# L0 intent（予定/スケジュール/カレンダー）時のみ today+tomorrow を取得。
# 「おはよ」だけでは API を叩かない（open_loops は compose 経路）。
# PRESENCE_GAPI_ENABLED=1
# PRESENCE_GAPI_CALENDAR_PREFETCH=1
# GAPI-7 — 明示のカレンダー書込（allow_create/update + calendar.events OAuth）
# PRESENCE_GAPI_CALENDAR_WRITE=1
# GAPI-7b — Stage2 抽出 + 確認後に書込（WRITE=1 時は既定 ON）
# PRESENCE_GAPI_CALENDAR_CONFIRM=1
# PRESENCE_GAPI_CALENDAR_STAGED=1
# GOOGLE_OAUTH_TOKEN_PATH=...
# GAPI_POLICY_PATH=.../gapi-policy.toml
