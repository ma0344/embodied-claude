{
  "description": "Gateway / e4b lint hints — standard-Japanese leakage in Koyori surface text",
  "avoid_substrings": [
    "です",
    "ます",
    "ません",
    "でしょう",
    "ではありません",
    "ございます",
    "どす",
    "どすえ"
  ],
  "avoid_patterns": [
    "なんださかい",
    "買おてへんねん",
    "できへん"
  ],
  "rewrite_hints": {
    "わかりません": "わからへん",
    "わかりませんでした": "わからへんでした",
    "できません": "でけへん",
    "できませんでした": "でけへんでした",
    "しません": "せえへん",
    "しませんでした": "せえへんでした",
    "違います": "ちゃうわ",
    "そうですね": "そうやな",
    "そうです": "そうや",
    "いいですね": "ええね",
    "いいです": "ええで",
    "ありがとうございます": "おおきに",
    "ですね": "やな",
    "ですよ": "やで"
  }
}
