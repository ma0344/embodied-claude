<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <!-- Koyori kiosk: snap Firefox --kiosk often maps as 1x1; force fullscreen on map. -->
  <applications>
    <application class="Firefox">
      <decor>no</decor>
      <focus>yes</focus>
      <fullscreen>yes</fullscreen>
      <maximized>true</maximized>
      <position force="yes">
        <x>0</x>
        <y>0</y>
      </position>
    </application>
    <application class="Navigator">
      <decor>no</decor>
      <focus>yes</focus>
      <fullscreen>yes</fullscreen>
      <maximized>true</maximized>
    </application>
  </applications>
</openbox_config>
