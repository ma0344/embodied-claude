# Required for ElevenLabs (optional if using Irodori / Aivis/VOICEVOX only)
# ELEVENLABS_API_KEY=your-api-key

# Optional defaults
ELEVENLABS_VOICE_ID=uYp2UUDeS74htH10iY2e
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_PLAY_AUDIO=true
ELEVENLABS_SAVE_DIR=/tmp/elevenlabs-t2s

# Irodori TTS (OpenAI-compatible HTTP API on :8088) — default engine
IRODORI_URL=http://127.0.0.1:8088
IRODORI_MODEL=irodori-tts
IRODORI_TIMEOUT_SEC=120
TTS_DEFAULT_ENGINE=irodori
# Inference recipe (voice, seed, cfg, caption): irodori-profile.toml
#   %USERPROFILE%\.config\embodied-claude\irodori-profile.toml
#   Example: docs/ops/irodori-profile.toml.example
# Override: IRODORI_PROFILE_PATH=

# AivisSpeech Engine (VOICEVOX-compatible HTTP API on :10101) — fallback
# VOICEVOX_URL=http://127.0.0.1:10101
# VOICEVOX_SPEAKER=345585728
# TTS_DEFAULT_ENGINE=voicevox

# Optional playback routing (useful on WSL)
# auto | paplay | elevenlabs | ffplay
ELEVENLABS_PLAYBACK=auto
# Set PulseAudio sink id (e.g., 1) when using paplay/WSL
ELEVENLABS_PULSE_SINK=
# Explicit PulseAudio server (WSLg default shown)
ELEVENLABS_PULSE_SERVER=unix:/mnt/wslg/PulseServer

# Camera speaker output via go2rtc backchannel (optional)
# When set, TTS audio is routed to the camera's built-in speaker via tapo:// protocol.
#
# TAPO_CAMERA_HOST: camera IP address (or use GO2RTC_CAMERA_HOST for tts-mcp-specific override)
TAPO_CAMERA_HOST=192.168.x.x
# GO2RTC_CAMERA_HOST=192.168.x.x
#
# RTSP/ONVIF uses the local camera account (set in the Tapo app under "Camera Account").
TAPO_USERNAME=your-camera-local-username
TAPO_PASSWORD=your-camera-local-password
# GO2RTC_CAMERA_USERNAME=your-camera-local-username
# GO2RTC_CAMERA_PASSWORD=your-camera-local-password
#
# tapo:// backchannel requires the TP-Link cloud account password (your Tapo app login).
# This is a DIFFERENT credential from the local camera account above.
# Falls back to TAPO_PASSWORD if not set (for backward compatibility).
TAPO_CLOUD_PASSWORD=your-tplink-cloud-password
# GO2RTC_CAMERA_CLOUD_PASSWORD=your-tplink-cloud-password
#
# Advanced go2rtc options (usually not needed)
# GO2RTC_URL=http://localhost:1984     # use existing go2rtc instance
# GO2RTC_BIN=/path/to/go2rtc          # custom binary path
# GO2RTC_CONFIG=/path/to/go2rtc.yaml  # custom config file
# GO2RTC_AUTO_START=true
# GO2RTC_STREAM=tapo_cam
# GO2RTC_FFMPEG=ffmpeg
